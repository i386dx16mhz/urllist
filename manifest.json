{
  "name": "URLリスト",
  "short_name": "URLリスト",
  "description": "URLを共有して保存するリストアプリ",
  "start_url": "/urllist/",
  "scope": "/urllist/",
  "display": "standalone",
  "background_color": "#111118",
  "theme_color": "#111118",
  "orientation": "portrait",
  "icons": [
    {
      "src": "/urllist/icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/urllist/icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "share_target": {
    "action": "/urllist/",
    "method": "GET",
    "params": {
      "title": "share_title",
      "text": "share_text",
      "url": "share_url"
    }
  }
}
